  IBUF clk_ibuf (
    .O(clk_d),
    .I(clk) 
);
  IBUF wdi_pin_ibuf (
    .O(wdi_pin_d),
    .I(wdi_pin) 
);
  IBUF en_hw_pin_ibuf (
    .O(en_hw_pin_d),
    .I(en_hw_pin) 
