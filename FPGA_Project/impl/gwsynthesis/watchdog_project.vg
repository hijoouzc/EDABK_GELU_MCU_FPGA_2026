    .wdi_debounced(wdi_debounced),
    .button_o_prev(button_o_prev)
);
  sync_debounce_0 u_debounce_en (
    .clk_d(clk_d),
    .n47_6(n47_6),
    .en_hw_pin_d(en_hw_pin_d),
